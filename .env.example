# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Kaggle credentials ──────────────────────────────────────────────────────
# Get from https://www.kaggle.com/settings → API → Create New Token
# The downloaded kaggle.json contains these two values.
KAGGLE_USERNAME=XXX
KAGGLE_KEY=XXXXX

# ── ClickHouse credentials ──────────────────────────────────────────────────
# Leave CLICKHOUSE_PASSWORD blank to run without a password (default config)
CLICKHOUSE_USER=XXX
CLICKHOUSE_PASSWORD=XXXX

# ── ClickHouse connection (used by load_to_olap.py) ─────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=imdb
